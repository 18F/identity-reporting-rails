{
  // Repo-specific opencode settings only. Shared/global settings live in the Team Data sbx mixin kit:
  // https://gitlab.login.gov/lg-teams/Team-Data/data-warehouse-ag/-/blob/main/sbx-kits/team-data/files/home/team-config/opencode.jsonc
  "$schema": "https://opencode.ai/config.json",

  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],

  "permission": {
    "read": {
      "**/credentials.yml.enc": "deny",
      "**/config/application.yml": "deny",
      "**/.databag_secret": "deny",
      "**/databag_secrets.json": "deny",
      ".envrc": "deny"
    }
  }
}
