{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "echo *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git check-attr *": "allow",
      "git ls-files *": "allow",
      "git remote *": "allow",
      "glab *": "ask",
      "glab issue list*": "allow",
      "glab issue view *": "allow",
      "glab mr list*": "allow",
      "glab mr view *": "allow",
      "glab mr diff *": "allow",
      "printf *": "allow",
      "read *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "terraform fmt *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow"
    },
    "read": {
      "**/credentials.yml.enc": "deny",
      "**/config/application.yml": "deny",
      "**/.databag_secret": "deny",
      "**/databag_secrets.json": "deny",
      ".envrc": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
