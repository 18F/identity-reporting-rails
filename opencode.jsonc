{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "echo *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "grep *": "allow",
      "printf *": "allow",
      "read *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "terraform fmt *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow"
    },
    "webfetch": "allow",
    "websearch": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
